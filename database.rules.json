{
  "rules": {
    "users": {
      "$emailKey": {
        ".read": "auth != null && (\n  auth.token.email.replace('.', ',') === $emailKey ||\n  (data.child('coachEmailKey').exists() &&\n   auth.token.email.replace('.', ',') === data.child('coachEmailKey').val())\n)",

        ".write": "auth != null && (\n  auth.token.email.replace('.', ',') === $emailKey ||\n  (data.child('coachEmailKey').val() !== null &&\n   auth.token.email.replace('.', ',') === data.child('coachEmailKey').val())\n)",

        "status": {
          ".validate": "newData.val() !== 'AUTONOMIE_PREMIUM' || data.val() === 'AUTONOMIE_PREMIUM'"
        },

        "paymentStatus": {
          ".validate": "newData.val() !== 'active' || data.val() === 'active'"
        },

        "paypalSubscriptionId": {
          ".validate": "newData.val() === data.val() || !newData.exists()"
        }
      }
    },

    "deleted_accounts": {
      ".read": false,
      ".write": false
    }
  }
}
